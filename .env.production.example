# Copiar a .env en el servidor y rellenar los valores

# PostgreSQL
POSTGRES_PASSWORD=pon-una-password-segura-aqui

# Better Auth — genera con: openssl rand -base64 32
BETTER_AUTH_SECRET=pon-un-secreto-de-32-chars-aqui

# URLs — reemplazar con la IP del VPS o dominio real
# Si usas solo IP: http://1.2.3.4  (la API en puerto 3000 directo, o con subdominio)
API_URL=http://TU_IP_O_DOMINIO_API
WEB_URL=http://TU_IP_O_DOMINIO_WEB
