# ============================================================
# Paperly — Variables de entorno para producción (docker-compose)
# ============================================================
# Copiar este archivo como .env en el servidor y rellenar los valores.
# NO commitear el .env real — este archivo sí va al repo.
#
# Cómo generar BETTER_AUTH_SECRET:
#   openssl rand -base64 32
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# Password del usuario "paperly" en Postgres (el usuario se crea automáticamente)
POSTGRES_PASSWORD=pon-una-password-segura-aqui

# ── Auth ─────────────────────────────────────────────────────
# Secreto compartido entre API y Web — deben ser EXACTAMENTE iguales
BETTER_AUTH_SECRET=pon-un-secreto-de-32-chars-aqui

# ── URLs públicas ────────────────────────────────────────────
# URL pública de la API (sin trailing slash)
# Ejemplo con dominio:   https://api.paperly.com
# Ejemplo con IP directa: http://1.2.3.4:4000
API_URL=https://api.tudominio.com

# URL pública del frontend (sin trailing slash)
WEB_URL=https://tudominio.com

# URL WebSocket de la API — para suscripciones en tiempo real
# Mismo host que API_URL pero con protocolo ws:// o wss://
# Si la API tiene HTTPS usa wss://, si es HTTP usa ws://
# Siempre termina en /graphql
WS_URL=wss://api.tudominio.com/graphql

# ── Cloudflare R2 (almacenamiento de archivos) ───────────────
# Crear bucket en https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=tu-r2-access-key-id
R2_SECRET_ACCESS_KEY=tu-r2-secret-access-key
R2_ENDPOINT=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=paperly-uploads

# ── IA — Groq (respuestas automáticas de IA) ─────────────────
# API key gratuita en https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=production
