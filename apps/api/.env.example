# ============================================================
# Paperly API — Variables de entorno (desarrollo local)
# ============================================================
# Copiar como apps/api/.env y rellenar los valores.
#
# Cómo generar BETTER_AUTH_SECRET:
#   openssl rand -base64 32
# ============================================================

# ── Base de datos ────────────────────────────────────────────
# Postgres local — el usuario/contraseña deben coincidir con tu instancia
DATABASE_URL=postgresql://paperly:paperly@localhost:5432/paperly

# ── Auth ─────────────────────────────────────────────────────
# Debe ser IGUAL al BETTER_AUTH_SECRET del frontend (apps/web/.env.local)
BETTER_AUTH_SECRET=change-this-to-a-random-32-char-string

# ── URLs ─────────────────────────────────────────────────────
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# Puerto en que escucha la API
PORT=3000

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=development

# ── Cloudflare R2 (almacenamiento de archivos) ───────────────
# Crear bucket en https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=paperly-uploads

# ── IA — Groq (respuestas automáticas de IA) ─────────────────
# API key gratuita en https://console.groq.com
GROQ_API_KEY=your-groq-api-key
