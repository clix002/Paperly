{
  "name": "@paperly/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "bunx --bun @biomejs/biome check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "cd ../../packages/db && bun run db:generate",
    "db:migrate": "cd ../../packages/db && bun run db:migrate",
    "db:push": "cd ../../packages/db && bun run db:push",
    "db:studio": "cd ../../packages/db && bun run db:studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@graphql-tools/schema": "^10.0.31",
    "@paperly/db": "workspace:*",
    "@paperly/shared": "workspace:*",
    "better-auth": "^1.2.8",
    "dataloader": "^2.2.3",
    "drizzle-orm": "^0.45.1",
    "es-toolkit": "^1.45.1",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.8",
    "graphql-yoga": "^5.13.4",
    "groq-sdk": "^1.1.2",
    "hono": "^4.7.11",
    "nanoid": "^5.1.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5"
  }
}
