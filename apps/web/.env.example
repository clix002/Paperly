# ============================================================
# Paperly Web — Variables de entorno (desarrollo local)
# ============================================================
# Copiar como apps/web/.env.local y rellenar los valores.
# Las variables NEXT_PUBLIC_* son visibles en el browser.
# ============================================================

# ── API ──────────────────────────────────────────────────────
# URL pública de la API — usada por el browser para GraphQL HTTP
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL interna de la API — usada por Next.js server-side (SSR/RSC)
# En Docker apunta al nombre del servicio: http://api:4000
INTERNAL_API_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────
# Debe ser IGUAL al BETTER_AUTH_SECRET del backend (apps/api/.env)
BETTER_AUTH_SECRET=change-this-to-same-value-as-api

# ── WebSocket (suscripciones en tiempo real) ──────────────────
# URL directa a la API con protocolo ws:// — NO pasa por el proxy de Next.js
# En producción usar wss:// si la API tiene HTTPS
NEXT_PUBLIC_WS_URL=ws://localhost:3000/graphql
